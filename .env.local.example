# Salesforce Connected App Configuration
# Create an External Client App in Salesforce Setup with these settings:
# - OAuth Settings: Enable "Authorization Code and Credentials Flow"
# - Callback URL: https://your-domain.vercel.app/auth/callback (or http://localhost:3000/auth/callback for local)
# - OAuth Scopes: api, cdp_api, refresh_token

# Your Salesforce Connected App Client ID
NEXT_PUBLIC_SF_CLIENT_ID=your_client_id_here

# Salesforce Login URL (default: https://login.salesforce.com)
# Use your custom domain if you have one, e.g., https://mydomain.my.salesforce.com
NEXT_PUBLIC_SF_LOGIN_URL=https://login.salesforce.com

# Optional: OpenAI API Key for enhanced chatbot (leave empty for local fallback mode)
OPENAI_API_KEY=
